# GodMode — Environment Variables
# Copy this file to .env and fill in your values.

# ── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key — powers agent spawning, auto-titling, identity extraction.
# This is the ONLY required key. Get yours at: console.anthropic.com
ANTHROPIC_API_KEY=

# ── Recommended ──────────────────────────────────────────────────────────────

# Memory — persistent conversational memory (recommended)
# Without this, GodMode works fine — you just won't have persistent memory across sessions.
# Get your key at: app.honcho.dev
HONCHO_API_KEY=

# Override memory provider (auto-detected from API keys if not set)
# Options: "honcho" | "none"
# GODMODE_MEMORY_PROVIDER=

# ── Optional ─────────────────────────────────────────────────────────────────

# Obsidian vault path for Second Brain (default: ~/Documents/VAULT, fallback: ~/godmode/memory/)
# OBSIDIAN_VAULT_PATH=

# Google Calendar via gog CLI
# GOG_CALENDAR_ACCOUNT=
# GOG_CLIENT=
# GOG_KEYRING_PASSWORD=

# X/Twitter intelligence (Grok API)
# XAI_API_KEY=

# Composio — optional managed OAuth for 850+ tools
# Your existing integrations work without this
# Get your key at: composio.dev (optional)
# COMPOSIO_API_KEY=

# Paperclip — multi-agent orchestration
# PAPERCLIP_URL=
# PAPERCLIP_API_KEY=

# Oura Ring health data for daily brief
# OURA_API_TOKEN=

# Override workspace owner identifier (defaults to "owner")
# GODMODE_OWNER=

# Override workspace root (defaults to ~/godmode)
# GODMODE_ROOT=
