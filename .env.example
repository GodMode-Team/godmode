# GodMode Plugin — Environment Variables
# Copy this file to .env and fill in your values.

# ── Core ──────────────────────────────────────────────────────────────────────

# Your OpenClaw API key (required)
OPENCLAW_API_KEY=

# ── Honcho — Persistent User Memory ──────────────────────────────────────────

# Honcho — persistent user memory (required for memory features)
# Get your key at: app.honcho.dev
HONCHO_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Override the GodMode workspace owner identifier (defaults to "owner")
# GODMODE_OWNER=
