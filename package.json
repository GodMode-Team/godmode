{
  "name": "@godmode-team/godmode",
  "version": "1.2.0",
  "private": false,
  "description": "GodMode - Personal AI Operating System plugin for OpenClaw",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./plugin.json": "./openclaw.plugin.json"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GodMode-Team/godmode-plugin.git"
  },
  "homepage": "https://lifeongodmode.com",
  "bugs": {
    "url": "https://github.com/GodMode-Team/godmode-plugin/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "godmode",
    "ai-os",
    "personal-ai",
    "productivity"
  ],
  "scripts": {
    "build": "pnpm build:ui && pnpm build:code && pnpm bundle:ui",
    "build:code": "tsup",
    "build:ui": "vite build --config ui/vite.config.ts",
    "bundle:ui": "node scripts/bundle-ui.mjs",
    "dev:ui": "vite --config ui/vite.config.ts",
    "test:ui": "vitest run --config ui/vitest.config.ts",
    "ui:sync": "node scripts/sync-ui-from-repo.mjs",
    "clean": "rm -rf dist ui/dist",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "pnpm build && pnpm pack:check",
    "preversion": "pnpm typecheck",
    "version": "node scripts/sync-version.mjs && git add openclaw.plugin.json",
    "postversion": "git push && git push --tags",
    "release": "npm version patch && npm publish"
  },
  "dependencies": {
    "@noble/ed25519": "3.0.0",
    "chokidar": "^4.0.3",
    "dompurify": "^3.3.1",
    "json5": "^2.2.3",
    "lit": "^3.3.2",
    "clawhub": "^0.7.0",
    "marked": "^17.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.3",
    "openclaw": "^2026.2.23",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "7.3.1"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0 <2027.0.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
